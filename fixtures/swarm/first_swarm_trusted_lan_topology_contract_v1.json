      "phase": "validate_linux_contributor",
      "actor": "linux_contributor",
      "command": "scripts/check-swarm-linux-4080-bringup.sh --report ${LINUX_RUN_ROOT}/reports/swarm_linux_rtx4080_bringup_v1.json",
