    "contributor_endpoint_manifest_object": "manifests/psion_google_two_node_swarm_contributor_endpoint_manifest.json",
    "coordinator_runtime_report_object": "host/coordinator/psion_google_two_node_swarm_runtime_report.json",
    "contributor_runtime_report_object": "host/contributor/psion_google_two_node_swarm_runtime_report.json",
    "final_manifest_object": "final/psion_google_two_node_swarm_final_manifest.json"
  },
  "zone_pair_fallback_order": [
    "us-central1-a__us-central1-b",
