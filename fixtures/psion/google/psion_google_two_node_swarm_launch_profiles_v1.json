    "rustup_default_toolchain": "stable",
    "pre_training_command": "cargo build -q -p psionic-train --bin psion_google_two_node_configured_peer_open_adapter_swarm",
    "training_command": "cargo run -q -p psionic-train --bin psion_google_two_node_configured_peer_open_adapter_swarm -- --role \"$PSION_SWARM_ROLE\" --cluster-manifest \"$PSION_CLUSTER_MANIFEST_FILE\" --local-endpoint \"$PSION_LOCAL_ENDPOINT_FILE\" --peer-endpoint \"$PSION_PEER_ENDPOINT_FILE\" --output \"$PSION_RUNTIME_REPORT_FILE\"",
    "endpoint_manifest_timeout_seconds": 900,
    "endpoint_manifest_poll_interval_seconds": 5
  },
  "artifact_paths": {
    "cluster_manifest_object": "launch/psion_google_two_node_swarm_cluster_manifest.json",
    "launch_receipt_object": "launch/psion_google_two_node_swarm_launch_receipt.json",
    "startup_script_object": "launch/psion-google-two-node-swarm-startup.sh",
