    },
    {
      "source_family_id": "normative_specs",
      "content_class": "spec_text",
      "sampling_weight_bps": 5000,
      "maximum_family_token_share_bps": 5000,
      "rationale": "Keep spec text at parity so the lane does not lose normative reading ability."
    }
  ],
  "source_contribution_caps": [
    {
      "source_id": "arch_textbook_foster_1985",
