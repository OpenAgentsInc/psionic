      "rationale": "One textbook may not dominate the prose share on its own."
    },
    {
      "source_id": "wasm_core_spec_release_2",
      "maximum_source_token_share_bps": 5000,
      "rationale": "One normative spec may not dominate the full mixture."
    }
  ],
  "repetitive_region_controls": [
    {
      "source_id": "arch_textbook_foster_1985",
      "document_id": "arch_textbook_foster_1985:chapter_01",
      "section_id": "arch_textbook_foster_1985:ch01:s02",
      "downweight_multiplier_bps": 5500,
