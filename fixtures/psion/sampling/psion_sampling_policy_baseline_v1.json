    {
      "content_class": "code",
      "observed_token_share_bps": 0
    }
  ],
  "regression_thresholds": [
    {
      "regression_kind": "explanation_quality",
      "maximum_regression_bps": 150,
      "rationale": "Explanatory quality may not regress materially when the mixture changes."
    },
    {
      "regression_kind": "spec_interpretation",
      "maximum_regression_bps": 100,
      "rationale": "Specification interpretation is a core Psion bar."
    },
    {
      "regression_kind": "tradeoff_reasoning",
      "maximum_regression_bps": 100,
      "rationale": "Tradeoff reasoning must remain stable across mixture updates."
    },
    {
      "regression_kind": "invariant_articulation",
      "maximum_regression_bps": 100,
      "rationale": "Invariant articulation must not erode under corpus expansion."
    },
    {
      "regression_kind": "coding_fluency",
      "maximum_regression_bps": 300,
      "rationale": "Coding fluency is tracked, but it does not outrank reasoning quality."
    }
  ]
