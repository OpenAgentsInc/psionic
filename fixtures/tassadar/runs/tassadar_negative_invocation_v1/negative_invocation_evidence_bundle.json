    "penalty_weights": [
      {
        "penalty_kind": "evidence_quality_regression",
        "weight_bps": 2100,
        "note": "a route that worsens evidence quality should be treated as a planner failure even when it still returns a locally correct answer"
      },
      {
        "penalty_kind": "fallback_churn",
        "weight_bps": 2600,
        "note": "fallback churn should stay visible because repeated internal retries are not a success metric and often destroy cost or latency posture"
      },
      {
        "penalty_kind": "refusal_when_better_lane_exists",
        "weight_bps": 1900,
        "note": "the planner should be penalized when it selects a route likely to refuse even though a better admissible lane already exists"
      },
      {
        "penalty_kind": "unnecessary_internal_invocation",
        "weight_bps": 3400,
        "note": "planners should pay an explicit penalty when the internal executor is invoked even though language-only or external delegation is the honest better lane"
      }
    ],
    "benchmarked_workload_classes": [
      "arithmetic_microprogram",
      "branch_heavy_kernel",
      "long_loop_kernel",
      "memory_heavy_kernel",
      "memory_lookup_microprogram",
      "sudoku_class"
    ],
    "target_surfaces": [
      "crates/psionic-models",
      "crates/psionic-train",
      "crates/psionic-router",
      "crates/psionic-eval"
    ],
    "validation_refs": [
