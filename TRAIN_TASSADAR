#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
rustflags="${RUSTFLAGS:-}"

if [[ -n "${rustflags}" ]]; then
  rustflags="${rustflags} -Awarnings"
else
  rustflags="-Awarnings"
fi

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  exec env RUSTFLAGS="${rustflags}" cargo run -q -p psionic-train --example tassadar_train_operator -- --help
fi

exec env RUSTFLAGS="${rustflags}" cargo run -q -p psionic-train --example tassadar_train_operator -- "$@"
